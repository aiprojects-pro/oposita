# Copia este archivo a «.env» y ajusta los valores.
#   cp .env.example .env

# Contraseña del panel de administración (OBLIGATORIA).
# Usa una clave larga y única. NO la compartas ni la subas al repositorio.
ADMIN_PASSWORD=cambia_esta_clave_por_una_segura

# Puerto interno del contenedor (opcional, por defecto 3000).
PORT=3000
